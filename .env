# at-least-once-bench environment configuration
# All services configured here

# Shared Infrastructure
POSTGRES_PORT=5432
POSTGRES_USER=bench
POSTGRES_PASSWORD=benchpass
POSTGRES_DB=benchdb

DOWNSTREAM_PORT=8080
DOWNSTREAM_METRICS_PORT=8081

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# RabbitMQ Framework
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=bench
RABBITMQ_PASSWORD=benchpass
RABBITMQ_WORKER_METRICS_PORT=9094

# NATS Framework
NATS_PORT=4222
NATS_MONITORING_PORT=8222
NATS_WORKER_METRICS_PORT=9095

# Kafka Framework
KAFKA_PORT=9092
KAFKA_WORKER_METRICS_PORT=9092

# Temporal Framework
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8081
TEMPORAL_WORKER_METRICS_PORT=9091

# Benchmark Runner
BENCHMARK_RATE=100
BENCHMARK_DURATION=60s
BENCHMARK_WARMUP=10s
BENCHMARK_COOLDOWN=20s
